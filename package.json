{
  "name": "bun-hono-boilerplate",
  "author": "Jovanka Samudra",
  "scripts": {
    "prepare:install": "lefthook install",
    "dev": "bun run --hot --env-file=.env src/index.ts",
    "biome:format": "biome format --write",
    "biome:lint": "biome lint --write",
    "biome:check": "biome check --write",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "generate": "plop",
    "generate:module": "plop module",
    "generate:module:all": "plop module-all",
    "generate:route": "plop register-route",
    "generate:schema": "plop add-schema"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.5",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.10.7",
    "pg": "^8.16.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@types/bun": "latest",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.7",
    "inquirer": "^9",
    "lefthook": "^2.0.4",
    "plop": "^4.0.5"
  }
}